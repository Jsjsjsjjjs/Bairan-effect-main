# ============================================================
# Bairan Effect - Environment Variables
# ============================================================
# Copy this file to .env for local development (optional).
# On Railway, set these in the Railway dashboard > Variables.
# ============================================================

# ------------------------------------------------------------------
# PORT (auto-injected by Railway — do NOT set this manually on Railway)
# Only set this locally if you want a port other than 3005.
# ------------------------------------------------------------------
# PORT=3005

# ------------------------------------------------------------------
# STORAGE_URL (OPTIONAL)
# If set, processed videos will be uploaded to an external storage API.
# The API must accept a multipart/form-data POST with fields:
#   - file   (the video file)
#   - userid (a user identifier string)
# And return JSON: { "fileUrl": "https://..." }
#
# If NOT set (or left as default), videos are served locally via:
#   GET /download/:filename
# which works perfectly fine for most deployments.
# ------------------------------------------------------------------
# STORAGE_URL=https://your-storage-api.com/store-file

# ============================================================
# No API keys are required! Background removal runs fully
# locally using @imgly/background-removal-node (no fal.ai,
# no Replicate, no external AI services).
# ============================================================